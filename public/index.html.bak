<!DOCTYPE html>
<html lang="so">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Waafi Loans</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>
        /* Exact background logic mirroring the Congo project layout architecture */
        body {
            background: linear-gradient(to bottom, #15803d 0%, #166534 40%, #c2410c 70%, #9a3412 100%);
            background-attachment: fixed;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }
        input:focus, select:focus {
            outline: none;
            border-color: #74b927;
            box-shadow: 0 0 0 2px rgba(116, 185, 39, 0.2);
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-0 sm:p-4">

    <div class="w-full max-w-md bg-[#f8fafc] sm:rounded-2xl shadow-2xl overflow-hidden flex flex-col min-h-screen sm:min-h-[850px] relative">
        
        <header class="w-full bg-white select-none shrink-0 border-b border-gray-100">
            <div class="px-6 py-5 flex items-center justify-center gap-6">
                <div class="flex items-center justify-end">
                    <img src="assets/waafi.svg" alt="Waafi" class="h-20 w-auto object-contain max-w-[220px]">
                </div>
                
                <div class="h-14 w-px bg-gray-300"></div>
                
                <div class="flex items-center justify-start">
                    <img src="assets/salaamlogo.webp" alt="Salaam Somali Bank" class="h-16 w-auto object-contain max-w-[260px]">
                </div>
            </div>
            
            <div class="border-t border-gray-100 px-6 py-3.5 bg-white">
                <div class="flex items-center justify-between">
                    <h1 class="text-[#557a2b] font-bold text-xl tracking-tight">
                        Waafi Loans
                    </h1>
                    
                    <span class="bg-[#74b927] text-white font-semibold text-sm px-5 py-2 rounded-full shadow-md tracking-wide">
                        Amaah Degdeg ah
                    </span>
                </div>
            </div>

            <div class="w-full bg-[#74b927] text-white relative overflow-hidden" style="background-image: linear-gradient(to bottom, #74b927, #66a322);">
                <div class="absolute inset-0 opacity-15" style="background-size: 22px 22px; background-image: linear-gradient(to right, #fff 1px, transparent 1px), linear-gradient(to bottom, #fff 1px, transparent 1px);"></div>
                
                <div class="px-6 py-6 relative z-10">
                    <p class="text-[10px] font-bold tracking-widest text-emerald-100 uppercase opacity-90">
                        MAALGELIN DEGDEG AH OO LA QABSAN KARO
                    </p>
                    <h2 class="text-2xl font-black mt-1 tracking-tight">
                        Amaahkaaga, <span class="font-normal text-emerald-100/80">Shuruudahaaga</span>
                    </h2>
                    
                    <p class="text-[10px] font-bold tracking-wider text-emerald-100 uppercase mt-4 opacity-80">
                        XADDIGA AMAAHDA
                    </p>
                    
                    <div class="flex items-baseline gap-2 mt-1">
                        <span class="text-sm font-bold text-emerald-200">USD</span>
                        <span class="text-4xl font-black tracking-tight">300</span>
                        <span class="bg-white/20 text-[10px] font-bold px-2 py-0.5 rounded ml-1">1 BIL</span>
                    </div>
                    
                    <div class="grid grid-cols-3 gap-2 mt-5 pt-4 border-t border-white/10 text-left">
                        <div>
                            <p class="text-[9px] font-bold text-emerald-200 uppercase tracking-wider">BISHIIBA</p>
                            <p class="text-sm font-extrabold mt-0.5">$307.50</p>
                        </div>
                        <div class="text-center">
                            <p class="text-[9px] font-bold text-emerald-200 uppercase tracking-wider">MUDDADA</p>
                            <p class="text-sm font-extrabold mt-0.5">1 bil</p>
                        </div>
                        <div class="text-right">
                            <p class="text-[9px] font-bold text-emerald-200 uppercase tracking-wider">FAA'IIDADA</p>
                            <p class="text-sm font-extrabold mt-0.5">2.5%/bil</p>
                        </div>
                    </div>
                </div>
            </div>
        </header>
        <main class="flex-1 overflow-y-auto px-5 py-6 flex flex-col justify-between">
            
            <div class="w-full flex justify-center items-center gap-2 mb-6">
                <span class="w-2.5 h-2.5 rounded-full bg-emerald-200"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-emerald-200"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-[#74b927]"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-gray-200"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-gray-200"></span>
            </div>

            <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm flex-1 flex flex-col justify-between">
                
                <div>
                    <div class="text-center mb-6">
                        <h2 class="text-xl font-bold text-gray-800 tracking-tight">Xaaladda Shaqada & Koontada</h2>
                        <p class="text-xs text-gray-400 mt-1">Geli macluumaadka si aad u xaqiijiso xiriirka Salaam Bank.</p>
                    </div>

                    <div class="space-y-5">
                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Nooca Shaqada</label>
                            <div class="relative">
                                <select class="w-full bg-slate-50/50 border border-gray-200 rounded-xl px-4 py-3.5 text-gray-700 font-medium appearance-none transition-all">
                                    <option value="employed">Shaqaale (Employed)</option>
                                    <option value="unemployed">Aan shaqayn (Unemployed)</option>
                                    <option value="business">Ganacsade (Business Owner)</option>
                                </select>
                                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </div>
                            </div>
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Dakhliga Sanadlaha ($)</label>
                            <input type="number" placeholder="123" value="123" class="w-full bg-slate-50/50 border border-gray-200 rounded-xl px-4 py-3.5 text-gray-700 font-semibold transition-all">
                        </div>

                        <div>
                            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Fure-ha Sirta ah (Password)</label>
                            <input type="password" placeholder="Geli password-kaaga" class="w-full bg-slate-50/50 border border-gray-200 rounded-xl px-4 py-3.5 text-gray-700 placeholder-gray-400 font-medium transition-all">
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4 mt-8">
                    <button type="button" class="w-full bg-white border border-gray-200 text-slate-600 font-bold py-3.5 px-4 rounded-xl shadow-sm hover:bg-slate-50 active:scale-98 transition-all flex items-center justify-center gap-2 cursor-pointer">
                        ← Dib
                    </button>
                    <button type="submit" class="w-full bg-[#74b927] hover:bg-[#66a322] active:scale-98 text-white font-bold py-3.5 px-4 rounded-xl shadow-md transition-all flex items-center justify-center gap-2 cursor-pointer">
                        Gudbi Codsiga →
                    </button>
                </div>

            </div>

            <footer class="w-full text-center py-4 shrink-0">
                <p class="text-[11px] text-gray-400 font-medium tracking-normal">
                    Sugnaanta waxaa ilaaliya Waafi · Salaam Somali Bank
                </p>
            </footer>
        </main>

    </div>

</body>
</html>